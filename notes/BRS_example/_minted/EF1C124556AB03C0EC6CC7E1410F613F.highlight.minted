\PYG{c}{\PYGZpc{}\PYGZpc{} 1. 网格定义}
\PYG{n}{grid\PYGZus{}min}\PYG{+w}{ }\PYG{p}{=}\PYG{+w}{ }\PYG{p}{[}\PYG{o}{\PYGZhy{}}\PYG{l+m+mi}{5}\PYG{p}{;}\PYG{+w}{ }\PYG{o}{\PYGZhy{}}\PYG{l+m+mi}{5}\PYG{p}{;}\PYG{+w}{ }\PYG{o}{\PYGZhy{}}\PYG{n+nb}{pi}\PYG{p}{]}\PYG{p}{;}\PYG{+w}{    }\PYG{c}{\PYGZpc{} 计算区域的下边界}
\PYG{n}{grid\PYGZus{}max}\PYG{+w}{ }\PYG{p}{=}\PYG{+w}{ }\PYG{p}{[}\PYG{l+m+mi}{5}\PYG{p}{;}\PYG{+w}{ }\PYG{l+m+mi}{5}\PYG{p}{;}\PYG{+w}{ }\PYG{n+nb}{pi}\PYG{p}{]}\PYG{p}{;}\PYG{+w}{       }\PYG{c}{\PYGZpc{} 计算区域的上边界}
\PYG{n}{N}\PYG{+w}{ }\PYG{p}{=}\PYG{+w}{ }\PYG{p}{[}\PYG{l+m+mi}{41}\PYG{p}{;}\PYG{+w}{ }\PYG{l+m+mi}{41}\PYG{p}{;}\PYG{+w}{ }\PYG{l+m+mi}{41}\PYG{p}{]}\PYG{p}{;}\PYG{+w}{            }\PYG{c}{\PYGZpc{} 每一个维度的网格点数目}
\PYG{n}{pdDims}\PYG{+w}{ }\PYG{p}{=}\PYG{+w}{ }\PYG{l+m+mi}{3}\PYG{p}{;}\PYG{+w}{                  }\PYG{c}{\PYGZpc{} 第三个维度是周期性}
